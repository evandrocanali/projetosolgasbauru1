{
  "version": 2,
  "builds": [
    { "src": "index.php", "use": "vercel-php@0.7.2" },
    { "src": "admin.php", "use": "vercel-php@0.7.2" },
    { "src": "product.php", "use": "vercel-php@0.7.2" },
    { "src": "login.php", "use": "vercel-php@0.7.2" },
    { "src": "logout.php", "use": "vercel-php@0.7.2" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ]
