{
  "cleanUrls": true,
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/index.php", "destination": "/api/index.php" },
    { "source": "/admin", "destination": "/api/admin.php" },
    { "source": "/product", "destination": "/api/product.php" },
    { "source": "/login", "destination": "/api/login.php" },
    { "source": "/logout", "destination": "/api/logout.php" }
  ]
}
