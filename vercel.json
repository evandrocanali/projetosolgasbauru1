{
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.7.2" },
    "api/product.php": { "runtime": "vercel-php@0.7.2" },
    "api/login.php": { "runtime": "vercel-php@0.7.2" },
    "api/admin.php": { "runtime": "vercel-php@0.7.2" },
    "api/logout.php": { "runtime": "vercel-php@0.7.2" }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/index.php", "destination": "/api/index.php" },
    { "source": "/product.php", "destination": "/api/product.php" },
    { "source": "/login.php", "destination": "/api/login.php" },
    { "source": "/admin.php", "destination": "/api/admin.php" },
    { "source": "/logout.php", "destination": "/api/logout.php" }
  ]
}
